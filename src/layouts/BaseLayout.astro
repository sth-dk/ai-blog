---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ChuangLian 的 AI 博客' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href={base} class="logo">ChuangLian's AI Blog</a>
        <div class="nav-links">
          <a href={base}>首页</a>
          <a href={`${base}blog/`}>文章</a>
          <a href={`${base}about/`}>关于</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} ChuangLian. All rights reserved.</p>
    </footer>
  </body>
</html>

<style>
  @import '../styles/global.css';

  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(10px);
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1em 1.5em;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.2em;
    font-weight: 700;
    color: var(--color-text);
  }

  .logo:hover {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    gap: 1.5em;
  }

  .nav-links a {
    color: var(--color-text-secondary);
    font-size: 0.95em;
  }

  .nav-links a:hover {
    color: var(--color-accent);
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2em 1.5em;
    flex: 1;
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    text-align: center;
    padding: 2em 1.5em;
    color: var(--color-text-secondary);
    font-size: 0.85em;
  }
</style>
